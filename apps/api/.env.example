# =============================================================================
# Database
# =============================================================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/whatsapp_saas?schema=public"

# =============================================================================
# Redis
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379

# =============================================================================
# Evolution API (WhatsApp)
# =============================================================================
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua-chave-aqui

# =============================================================================
# JWT
# =============================================================================
JWT_SECRET=troque-em-producao-use-uma-string-longa-e-aleatoria
JWT_EXPIRES_IN=7d

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGIN=http://localhost:3000

# =============================================================================
# AI Backend
#  Valores: anthropic | ollama | openai-compatible
# =============================================================================
AI_BACKEND=anthropic
AI_CLASSIFIER_BACKEND=anthropic

# Anthropic (quando AI_BACKEND=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Ollama local (quando AI_BACKEND=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# vLLM / Together / Fireworks (quando AI_BACKEND=openai-compatible)
LLM_BASE_URL=https://api.together.xyz/v1
LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
LLM_API_KEY=

# =============================================================================
# Logging (dev-only, ignorado em produção)
# =============================================================================
# LOG_LEVEL controla o nível do logger do Nest (default: dev=error,warn,log,debug / prod=error,warn,log)
# Valores válidos separados por vírgula: error, warn, log, debug, verbose
# Exemplo: LOG_LEVEL=error,warn,log
# LOG_LEVEL=

# PRISMA_LOG controla os logs de SQL do Prisma
#   (vazio)  -> silencioso (só errors e warns)     ← recomendado
#   query    -> loga cada SQL com duração          (útil para achar N+1)
# PRISMA_LOG=

# HTTP_LOG controla o middleware de logs HTTP
#   (vazio)  -> 1 linha colorida por request       ← recomendado
#   verbose  -> também loga corpo das respostas 4xx/5xx
#   off      -> desliga
# HTTP_LOG=

NODE_ENV=development
PORT=3001
