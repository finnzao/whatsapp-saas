NODE_ENV=development
PORT=3001

# Banco de dados
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/whatsapp_saas?schema=public

# Redis (usado pela fila BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Evolution API
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=dev-evolution-key-change-me

# URL pública do backend (usada no webhook da Evolution)
APP_URL=http://localhost:3001

# IA - escolha um provider
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Modelo padrão (Claude Haiku é barato e rápido pra MVP)
AI_MODEL=claude-haiku-4-5-20251001

# CORS - URL do frontend
CORS_ORIGIN=http://localhost:3000
