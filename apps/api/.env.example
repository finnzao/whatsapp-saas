NODE_ENV=development
PORT=3001

# Banco de dados
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/whatsapp_saas?schema=public

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Evolution API
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=dev-evolution-key-change-me

# URL pública do backend (usada no webhook da Evolution)
APP_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3000

PRISMA_LOG=query
HTTP_LOG=verbose

# =============================================================================
# LLM Providers
# =============================================================================
# anthropic | ollama | openai-compatible
AI_BACKEND=ollama
# AI_CLASSIFIER_BACKEND=ollama  # opcional, default = AI_BACKEND

# ------- Anthropic -------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Default do SDK é 600s (10min) e 2 retries — alto demais pra chat.
ANTHROPIC_TIMEOUT_MS=30000
ANTHROPIC_MAX_RETRIES=0

# ------- Ollama -------
OLLAMA_BASE_URL=http://localhost:11434
# Recomendados (do mais rápido pro mais lento em CPU/GPU modesta):
#   llama3.2:3b      ~2GB, ~30 tok/s em CPU moderna   ← MAIS RÁPIDO com tool use
#   qwen2.5:3b       ~2GB, ~25 tok/s em CPU
#   qwen2.5:7b       ~5GB, ~10 tok/s em CPU, ~40 tok/s em RTX 3060
#   llama3.1:8b      ~5GB, ~10 tok/s em CPU
#   qwen2.5:14b      ~9GB, exige GPU
OLLAMA_MODEL=qwen2.5:7b
# Timeout do axios. Em Ollama local geração demora — não use isso pra
# "interromper", só pra detectar travamento real.
OLLAMA_TIMEOUT_MS=120000
# Mantém modelo carregado entre requests. 300s = primeira call paga o
# loading (~10s), próximas vão diretas. Suba se sua máquina tem RAM/VRAM.
OLLAMA_KEEP_ALIVE_S=300

# ------- OpenAI-compatible -------
LLM_BASE_URL=http://localhost:8000/v1
LLM_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
LLM_API_KEY=no-key-required

# =============================================================================
# AI Orchestration (limites do orquestrador)
# =============================================================================
# Budget total por mensagem (todas as iterações somadas). Ollama local é
# lento — 90s é defesa contra travamento, não interrupção de geração válida.
AI_TOTAL_BUDGET_MS=90000
# Timeout por chamada individual ao provider.
AI_PER_CALL_TIMEOUT_MS=60000
# Reduzir aqui é o controle MAIS DIRETO de latência: menos tokens = menos
# tempo de geração. 512 cobre respostas de chat normais.
AI_MAX_TOKENS_PER_CALL=512
# Em Ollama local, mais iterações = mais minutos de espera. 2 cobre o caso
# "1 tool call + 1 resposta humana" sem dar margem pra loop.
AI_MAX_ITERATIONS=2
