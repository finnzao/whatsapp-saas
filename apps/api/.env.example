# Application
APP_URL=http://localhost:3000
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/whatsapp_saas

# Redis (BullMQ + debouncer)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Evolution API
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your-global-api-key

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_CLASSIFIER_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_MS=60000

# Circuit breaker (round 2)
OLLAMA_BREAKER_THRESHOLD=2
OLLAMA_BREAKER_OPEN_MS=30000

# Inbound debouncer (round 3)
# Janela de espera após cada nova mensagem antes de processar (ms)
INBOUND_DEBOUNCE_MS=5000
# Teto absoluto: força processamento mesmo que cliente continue digitando (ms)
INBOUND_DEBOUNCE_MAX_MS=30000
# Quantidade máxima de mensagens em batch antes de forçar processamento
INBOUND_DEBOUNCE_MAX_MESSAGES=20

# WhatsApp typing indicator (Evolution sendPresence)
# Frequência do refresh enquanto bot está gerando resposta (ms)
PRESENCE_REFRESH_MS=8000
# Tempo máximo total que "digitando..." pode ficar ativo (proteção) (ms)
PRESENCE_MAX_LIFETIME_MS=120000
