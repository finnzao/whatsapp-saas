# Application
APP_URL=http://localhost:3000
PORT=3000
NODE_ENV=development

# Database (precisa de pgvector instalado)
# Em Docker: use imagem 'pgvector/pgvector:pg16' ou 'ankane/pgvector'
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/whatsapp_saas

# Redis (BullMQ + debouncer)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Evolution API
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your-global-api-key

# ============================================
# LLM principal (agente)
# ============================================
AI_BACKEND=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_CLASSIFIER_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_MS=60000

# Circuit breaker LLM
OLLAMA_BREAKER_THRESHOLD=2
OLLAMA_BREAKER_OPEN_MS=30000

# ============================================
# Embeddings (RAG vetorial — round 4)
# ============================================
# Provider: 'ollama' (local, gratuito) ou 'openai' (API paga)
AI_EMBEDDING_BACKEND=ollama

# Ollama embeddings
# Modelo recomendado: bge-m3 (qualidade alta, multilingual, 1024 dims)
# Alternativa leve: nomic-embed-text (mais rápido, 768 dims)
# Antes de subir: `ollama pull bge-m3`
OLLAMA_EMBEDDING_MODEL=bge-m3
OLLAMA_EMBEDDING_DIMENSIONS=1024
OLLAMA_EMBEDDING_TIMEOUT_MS=30000
OLLAMA_EMBEDDING_BREAKER_THRESHOLD=3
OLLAMA_EMBEDDING_BREAKER_OPEN_MS=20000

# OpenAI embeddings (alternativa)
# OPENAI_EMBEDDING_API_KEY=sk-...
# OPENAI_EMBEDDING_BASE_URL=https://api.openai.com/v1
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_EMBEDDING_DIMENSIONS=1536

# Worker de embeddings — quantos jobs em paralelo
# Mantenha baixo (1-3) se o Ollama está em CPU; maior se tem GPU
EMBEDDING_WORKER_CONCURRENCY=2

# ============================================
# Inbound debouncer (round 3)
# ============================================
INBOUND_DEBOUNCE_MS=5000
INBOUND_DEBOUNCE_MAX_MS=30000
INBOUND_DEBOUNCE_MAX_MESSAGES=20
PRESENCE_REFRESH_MS=8000
PRESENCE_MAX_LIFETIME_MS=120000
